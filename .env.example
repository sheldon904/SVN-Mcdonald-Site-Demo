# Google Maps API key for showcase property 3D map tours
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Prerender.io token for bot/crawler SSR (set in Vercel env vars)
# Sign up at https://prerender.io/ — free tier covers 250 pages/month
# Without this, non-JS crawlers (Bing, Facebook, LinkedIn, Twitter) see empty content
PRERENDER_TOKEN=your_prerender_token
